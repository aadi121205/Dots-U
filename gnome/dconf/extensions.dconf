tile-topright-quarter=['<Super>KP_9']
tile-topright-quarter-ignore-ta=@as []
tiling-popup-all-workspace=false
toggle-always-on-top=@as []
toggle-tiling-popup=@as []

[tilingshell]
cycle-layouts=['<Super>Page_Down']
cycle-layouts-backward=['<Shift><Super>Page_Down']
edge-tiling-mode='default'
edge-tiling-offset=uint32 36
enable-autotiling=true
enable-blur-selected-tilepreview=false
enable-blur-snap-assistant=true
enable-move-keybindings=true
enable-window-border=false
highlight-current-window=['<Super>Page_Up']
